# ── Solana RPC ──────────────────────────────────────────────────────────────
SOLANA_RPC_CONSTANTK=https://your-http-rpc.constant-k.com/...
SOLANA_RPC_HTTP=https://your-http-rpc.constant-k.com/...
SOLANA_RPC_URL=https://your-http-rpc.constant-k.com/...
SOLANA_WSS_URL=wss://your-wss-rpc.constant-k.com/...
SOLANA_RPC_QUICKNODE=https://your-endpoint.quiknode.pro/YOUR_KEY/
SOLANA_RPC_PUBLIC=https://api.mainnet-beta.solana.com
SOLANA_ALLOW_PUBLIC_RPC_FALLBACK=false
HELIUS_API_KEY=
BIRDEYE_API_KEY=

# ── Wallet ───────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY
WALLET_PUBLIC_KEY=YOUR_WALLET_PUBLIC_KEY

# ── Trading Controls ─────────────────────────────────────────────────────────
PAPER_TRADING=true
AUTONOMOUS_MODE=false
MAX_POSITION_SIZE_SOL=1.0
TOTAL_BUDGET_SOL=1.0
MIN_SCORE_THRESHOLD=65
DCA_DELAY_LEG1_MS=120000
DCA_DELAY_LEG2_MS=300000

# ── Jupiter ──────────────────────────────────────────────────────────────────
JUPITER_API_BASE=https://quote-api.jup.ag/v6
JUPITER_SLIPPAGE_BPS=300
SLIPPAGE=50

# ── RugCheck ─────────────────────────────────────────────────────────────────
RUGCHECK_API_BASE=https://api.rugcheck.xyz/v1
RUGCHECK_MIN_SCORE=70

# ── PumpPortal ───────────────────────────────────────────────────────────────
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data

# ── Twitter / X ──────────────────────────────────────────────────────────────
TWITTER_USERNAME=your_handle
TWITTER_PASSWORD=your_password
TWITTER_EMAIL=you@example.com
TWITTER_TOKEN=OPTIONAL_6551_OPENTWITTER_TOKEN
TWITTER_API_BASE=https://ai.6551.io
TWITTER_AUTO_KOL_DISCOVERY=true
TWITTER_DISCOVERY_KEYWORDS=pump.fun solana,solana ca,solana gem,raydium migration,new solana pair
TWITTER_MIN_FOLLOWERS=8000
TWITTER_MAX_DISCOVERED_HANDLES=20
TWITTER_BEARER_TOKEN=OPTIONAL_LEGACY_BEARER
TWITTER_KOL_USER_IDS=blknoiz06,DegenSpartan
TWITTER_POLL_INTERVAL_MS=120000

# ── Reddit (free social signal ingestion) ───────────────────────────────────
REDDIT_SUBREDDITS=SolanaCoins,memecoins,CryptoMoonShots
REDDIT_POLL_INTERVAL_MS=180000

# ── Smart Money Wallets (comma-separated Solana pubkeys) ─────────────────────
SMART_MONEY_WALLETS=wallet1pubkey,wallet2pubkey

# ── LLM via OpenRouter ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

FINDER_MODEL=anthropic/claude-sonnet-4-5
TRADER_MODEL=openai/gpt-4o-mini
AUDITOR_MODEL=openai/gpt-4o-mini

# ── Server ───────────────────────────────────────────────────────────────────
SOCKET_IO_PORT=3001
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
PGLITE_DATA_DIR=./.wildtrade-db

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
