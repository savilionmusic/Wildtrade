{
  "name": "wildtrade",
  "version": "1.0.0",
  "description": "Tri-squad multi-agent Solana trading bot desktop app and bundled bot runtime.",
  "author": "savilionmusic",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint packages/*/src src --ext .ts",
    "build:bot": "node scripts/build-bot.js",
    "electron:dev": "npm run build:bot && electron .",
    "build:mac": "npm run build:bot && electron-builder --mac --config.npmRebuild=false --config.nodeGypRebuild=false",
    "build:win": "npm run build:bot && electron-builder --win --config.npmRebuild=false --config.nodeGypRebuild=false",
    "build:linux": "npm run build:bot && electron-builder --linux --config.npmRebuild=false --config.nodeGypRebuild=false",
    "postinstall": "node -e \"process.exit(0)\""
  },
  "build": {
    "appId": "com.wildtrade.app",
    "productName": "Wildtrade",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "ui/**/*",
      "dist/**/*",
      "node_modules/**/*",
      "packages/*/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/",
        "to": "bot/dist/"
      },
      {
        "from": "node_modules/",
        "to": "bot/node_modules/"
      }
    ],
    "mac": {
      "category": "public.app-category.finance",
      "icon": "build/icon.png",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "build/icon.png",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage"]
    },
    "dmg": {
      "title": "Wildtrade",
      "backgroundColor": "#0d1117"
    },
    "npmRebuild": false
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@elizaos/adapter-sqljs": "^0.25.6-alpha.1",
    "@elizaos/core": "0.25.9",
    "@esbuild/linux-x64": "^0.28.0",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "socket.io": "^4.8.1",
    "sql.js": "^1.14.1",
    "twitter-api-v2": "^1.18.2",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "better-sqlite3": "./scripts/stub-better-sqlite3",
    "sharp": "./scripts/stub-sharp",
    "@anush008/tokenizers": "./scripts/stub-tokenizers",
    "fastembed": "./scripts/stub-fastembed"
  }
}
