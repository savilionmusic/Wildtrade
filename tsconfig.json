{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@wildtrade/shared": ["packages/shared/src/index.ts"],
      "@wildtrade/shared/*": ["packages/shared/src/*"],
      "@wildtrade/plugin-alpha-scout": ["packages/plugin-alpha-scout/src/index.ts"],
      "@wildtrade/plugin-smart-trader": ["packages/plugin-smart-trader/src/index.ts"],
      "@wildtrade/plugin-self-healer": ["packages/plugin-self-healer/src/index.ts"]
    }
  },
  "include": ["src/**/*", "packages/*/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
